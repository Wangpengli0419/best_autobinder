{
    "$schema": "./@types/schema/package/index.json",
    "package_version": 2,
    "name": "best_autobinder",
    "version": "1.0.0",
    "author": "Nasus",
    "editor": ">=3.8.3",
    "scripts": {
        "build": "tsc -b",
        "watch": "tsc -w"
    },
    "description": "i18n:best_autobinder.description",
    "main": "./dist/main.js",
    "dependencies": {
        "vue": "^3.1.4",
        "fs-extra": "^10.0.0"
    },
    "devDependencies": {
        "@cocos/creator-types": "^3.8.3",
        "@types/node": "^16.0.1",
        "@types/fs-extra": "^9.0.5",
        "typescript": "^4.3.4"
    },
    "panels": {
        "default": {
            "title": "best_autobinder Default Panel",
            "type": "dockable",
            "main": "dist/panels/default",
            "size": {
                "min-width": 400,
                "min-height": 300,
                "width": 1024,
                "height": 600
            }
        },
        "settings": {
            "title": "best_autobinder settings Panel",
            "type": "dockable",
            "main": "./dist/panels/settings/script",
            "icon": "./static/list.png",
            "size": {
                "min-width": 600,
                "min-height": 500,
                "width": 700,
                "height": 600
            },
            "flags": {
                "resizable": true,
                "alwaysOnTop": false
            }
        }
    },
    "contributions": {
        "menu": [
            {
                "path": "i18n:menu.extension/BestBinder",
                "label": "i18n:best_autobinder.bind",
                "message": "bind"
            },
            {
                "path": "i18n:menu.extension/BestBinder",
                "label": "i18n:best_autobinder.settings",
                "message": "open-settings"
            }
        ],
        "hierarchy": {
            "menu": {
                "methods": "./dist/menu/hierarchy-menu.js",
                "panelMenu": "onPanelMenu",
                "nodeMenu": "getNodeMenu",
                "rootMenu": "getNodeMenu"
            }
        },
        "messages": {
            "bind": {
                "methods": [
                    "bind"
                ]
            },
            "open-settings": {
                "methods": [
                    "openSettings"
                ]
            },
            "getCustomScripts": {
                "methods": [
                    "getCustomScripts"
                ]
            },
            "getScriptProperties": {
                "methods": [
                    "getScriptProperties"
                ]
            },
            "save-separator-map": {
                "methods": [
                    "saveSeparatorMap"
                ]
            },
            "get-separator-map": {
                "methods": [
                    "getSeparatorMap"
                ]
            },
            "get-alias-map": {
                "methods": [
                    "getAliasMap"
                ]
            },
            "save-alias-map": {
                "methods": [
                    "saveAliasMap"
                ]
            },
            "asset-change": {
                "methods": []
            }
        },
        "shortcuts": [
            {
                "message": "bind",
                "win": "alt+g",
                "mac": "alt+g"
            }
        ],
        "scene": {
            "script": "./dist/scene.js"
        }
    }
}